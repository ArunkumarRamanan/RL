# A100-80GB Instance Configuration
# Training: Qwen3-4B → Qwen3-1.7B-Base (OPD)
# 
# Based on default NeMo-RL distillation config:
# examples/configs/distillation_math.yaml
#
# UNIQUE: Different teacher (4B) from H200 instances (32B)
# This is the default tested pair in NeMo-RL

# Job identification
JOB_NAME="opd-a100-80-4b-to-1.7b"
ALGORITHM="distillation"

# Config file (relative to /opt/nemo-rl)
CONFIG_FILE="examples/configs/distillation_math.yaml"

# HuggingFace upload settings
HF_REPO="arunkumarvr/deepbrainz-r1-1.7b-math-4b-teacher"
MODEL_NAME="deepbrainz-r1-1.7b-math-4b-teacher"

# Training parameters (quality-focused)
MAX_STEPS="3000"
VAL_PERIOD="25"
SAVE_PERIOD="25"

# Extra config overrides for A100-80GB
# The default config uses TP=2, CP=2 for teacher, works on A100-80GB
EXTRA_OVERRIDES=""

# Container
CONTAINER_NAME="nemo-opd"
NRL_IMAGE="nvcr.io/nvidia/nemo-rl:v0.4.0"

# ============================================
# CREDENTIALS - FILL IN BEFORE DEPLOYMENT
# ============================================
WANDB_API_KEY="YOUR_WANDB_API_KEY"
HF_TOKEN="YOUR_HF_TOKEN"
