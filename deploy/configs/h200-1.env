# H200 Instance #1 Configuration
# Training: Qwen3-32B → Qwen3-4B-Base (OPD)
# 
# Based on tested NeMo-RL recipe:
# examples/configs/recipes/llm/distillation-qwen3-32b-to-4b-base-1n8g-fsdp2tp2-dynamicbatch.v1.yaml

# Job identification
JOB_NAME="opd-h200-1-32b-to-4b"
ALGORITHM="distillation"

# Config file (relative to /opt/nemo-rl)
CONFIG_FILE="examples/configs/recipes/llm/distillation-qwen3-32b-to-4b-base-1n8g-fsdp2tp2-dynamicbatch.v1.yaml"

# HuggingFace upload settings
HF_REPO="arunkumarvr/deepbrainz-r1-4b-math-reasoning"
MODEL_NAME="deepbrainz-r1-4b-math-reasoning"

# Training parameters (quality-focused)
MAX_STEPS="2000"
VAL_PERIOD="25"
SAVE_PERIOD="25"

# Extra config overrides for H200 (141GB VRAM per GPU)
# H200 can handle the default TP=8 for 32B teacher
EXTRA_OVERRIDES=""

# Container
CONTAINER_NAME="nemo-opd"
NRL_IMAGE="nvcr.io/nvidia/nemo-rl:v0.4.0"

# ============================================
# CREDENTIALS - FILL IN BEFORE DEPLOYMENT
# ============================================
WANDB_API_KEY="YOUR_WANDB_API_KEY"
HF_TOKEN="YOUR_HF_TOKEN"
