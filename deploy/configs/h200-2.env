# H200 Instance #2 Configuration
# Training: Qwen3-32B → Qwen3-1.7B-Base (OPD)
# 
# Based on tested NeMo-RL recipe:
# examples/configs/recipes/llm/distillation-qwen3-32b-to-1.7b-base-1n8g-fsdp2tp1.v1.yaml
#
# UNIQUE: Different student (1.7B) from H200-1 (4B)

# Job identification
JOB_NAME="opd-h200-2-32b-to-1.7b"
ALGORITHM="distillation"

# Config file (relative to /opt/nemo-rl)
CONFIG_FILE="examples/configs/recipes/llm/distillation-qwen3-32b-to-1.7b-base-1n8g-fsdp2tp1.v1.yaml"

# HuggingFace upload settings
HF_REPO="arunkumarvr/deepbrainz-r1-1.7b-math-reasoning"
MODEL_NAME="deepbrainz-r1-1.7b-math-reasoning"

# Training parameters (quality-focused)
MAX_STEPS="2500"
VAL_PERIOD="25"
SAVE_PERIOD="25"

# Extra config overrides
EXTRA_OVERRIDES=""

# Container
CONTAINER_NAME="nemo-opd"
NRL_IMAGE="nvcr.io/nvidia/nemo-rl:v0.4.0"

# ============================================
# CREDENTIALS - FILL IN BEFORE DEPLOYMENT
# ============================================
WANDB_API_KEY="YOUR_WANDB_API_KEY"
HF_TOKEN="YOUR_HF_TOKEN"
