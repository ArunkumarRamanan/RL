# A100-40GB Instance Configuration
# Training: Qwen3-8B-Base GRPO (RL training, not distillation)
# 
# Based on tested NeMo-RL GRPO recipe:
# examples/configs/recipes/llm/grpo-qwen3-8b-base-1n8g-fp8-kvcache-megatron.yaml
#
# UNIQUE: GRPO algorithm (not OPD), different model (8B-Base)
# Uses FP8 for efficient training on A100-40GB

# Job identification
JOB_NAME="grpo-a100-40-8b-base"
ALGORITHM="grpo"

# Config file (relative to /opt/nemo-rl)
CONFIG_FILE="examples/configs/recipes/llm/grpo-qwen3-8b-base-1n8g-fp8-kvcache-megatron.yaml"

# HuggingFace upload settings
HF_REPO="arunkumarvr/deepbrainz-r1-8b-math-grpo"
MODEL_NAME="deepbrainz-r1-8b-math-grpo"

# Training parameters (quality-focused)
MAX_STEPS="1000"
VAL_PERIOD="20"
SAVE_PERIOD="20"

# Extra config overrides for A100-40GB
# Enable checkpointing (disabled in default config)
# Adjust for 40GB VRAM
EXTRA_OVERRIDES="checkpointing.enabled=true checkpointing.checkpoint_dir=/mnt/ckpt/grpo-a100-40-8b-base policy.generation.vllm_cfg.gpu_memory_utilization=0.4"

# Container
CONTAINER_NAME="nemo-grpo"
NRL_IMAGE="nvcr.io/nvidia/nemo-rl:v0.4.0"

# ============================================
# CREDENTIALS - FILL IN BEFORE DEPLOYMENT
# ============================================
WANDB_API_KEY="YOUR_WANDB_API_KEY"
HF_TOKEN="YOUR_HF_TOKEN"
